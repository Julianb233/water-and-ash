# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Cloudinary ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# --- Resend (Transactional Email) ---
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=info@waterandashburials.org
RESEND_TO_EMAIL=info@waterandashburials.org

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://waterandashburials.org

# --- GoHighLevel CRM ---
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_ghl_location_id
GHL_BASE_URL=https://services.leadconnectorhq.com
GHL_WEBHOOK_SECRET=your_ghl_webhook_secret

# GHL B2C Pipeline Stage IDs
GHL_STAGE_NEW_LEAD=your_stage_id
GHL_STAGE_DEPOSIT_PAID=your_stage_id
GHL_STAGE_CEREMONY_SCHEDULED=your_stage_id
GHL_STAGE_COMPLETED=your_stage_id

# GHL B2B Pipeline (CRM-06: Partner Inquiry → Discovery → Agreement → Active Partner)
GHL_B2B_PIPELINE_ID=your_pipeline_id
GHL_B2B_STAGE_PARTNER_INQUIRY=your_stage_id
GHL_B2B_STAGE_DISCOVERY=your_stage_id
GHL_B2B_STAGE_AGREEMENT=your_stage_id
GHL_B2B_STAGE_ACTIVE_PARTNER=your_stage_id

# GHL Calendar IDs (one per vessel)
GHL_CALENDAR_OSPREY=your_calendar_id
GHL_CALENDAR_WHITE_NIGHTS=your_calendar_id
GHL_CALENDAR_RELENTLESS=your_calendar_id

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Stripe Price IDs
STRIPE_PRICE_OSPREY=price_xxx
STRIPE_PRICE_WHITE_NIGHTS=price_xxx
STRIPE_PRICE_RELENTLESS=price_xxx
STRIPE_PRICE_AT_HOME_MEMORIAL=price_xxx

# --- Cron Jobs ---
CRON_SECRET=your_cron_secret
