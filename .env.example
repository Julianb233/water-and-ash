# Cloudinary Configuration
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Resend Email Configuration
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=info@waterandashburials.org
RESEND_TO_EMAIL=info@waterandashburials.org

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://waterandashburials.org

# GoHighLevel CRM
GHL_API_KEY=your_ghl_api_key
GHL_LOCATION_ID=your_ghl_location_id
GHL_BASE_URL=https://services.leadconnectorhq.com

# GoHighLevel Webhook
GHL_WEBHOOK_SECRET=your_ghl_webhook_secret

# GoHighLevel Calendar IDs (per-vessel scheduling)
GHL_CALENDAR_OSPREY=your_osprey_calendar_id
GHL_CALENDAR_WHITE_NIGHTS=your_white_nights_calendar_id
GHL_CALENDAR_RELENTLESS=your_relentless_calendar_id

# Stripe Payment Processing
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Vercel Cron Secret
CRON_SECRET=your_cron_secret
